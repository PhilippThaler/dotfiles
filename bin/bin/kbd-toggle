#!/bin/bash
# kbd-toggle — Wayland edition
# Toggles ThinkPad keyboard backlight: off → low → high → off
# Uses brightnessctl (works on Wayland)

DEVICE="tpacpi::kbd_backlight"
MAX=2  # ThinkPad max brightness (0=off, 1=low, 2=high)

CURRENT=$(brightnessctl -d "$DEVICE" get 2>/dev/null || echo 0)

case "$CURRENT" in
    0) NEXT=1 ;;
    1) NEXT=2 ;;
    2) NEXT=0 ;;
    *) NEXT=0 ;;
esac

brightnessctl -d "$DEVICE" set "$NEXT"
