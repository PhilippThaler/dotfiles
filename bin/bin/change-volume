#!/bin/bash
# changeVolume — Wayland edition
# Changes volume via amixer/pactl and shows notification via notify-send

msgTag="myvolume"

# Change volume (works the same with amixer or pactl)
amixer -c 0 set Master "$@" > /dev/null

# Query current volume and mute status
volume="$(amixer -c 0 get Master | tail -1 | awk '{print $4}' | sed 's/[^0-9]*//g')"
mute="$(amixer -c 0 get Master | tail -1 | awk '{print $6}' | sed 's/[^a-z]*//g')"

if [[ $volume == 0 || "$mute" == "off" ]]; then
    notify-send -a "changeVolume" -u low -i audio-volume-muted \
        -h "string:x-canonical-private-synchronous:$msgTag" \
        "Volume muted"
else
    notify-send -a "changeVolume" -u low -i audio-volume-high \
        -h "string:x-canonical-private-synchronous:$msgTag" \
        -h "int:value:$volume" \
        "Volume: ${volume}%"
fi

# Play feedback sound (paplay is Wayland/PipeWire safe)
paplay /usr/share/sounds/freedesktop/stereo/audio-volume-change.oga 2>/dev/null
