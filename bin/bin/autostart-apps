#!/bin/bash
# Wait for Signal and Neomutt to appear on workspace 4, then return to ws1.
# Gives up after 30s if either fails to launch.

for i in $(seq 1 30); do
    if swaymsg -t get_tree | grep -q 'signal\|neomutt'; then
        sleep 0.5
        swaymsg workspace 1
        exit 0
    fi
    sleep 1
done

# Timed out — switch anyway
swaymsg workspace 1
