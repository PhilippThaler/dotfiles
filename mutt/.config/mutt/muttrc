# vim: filetype=neomuttrc
source /usr/share/mutt-wizard/mutt-wizard.muttrc # mw-autogenerated
source /home/philipp/.config/mutt/accounts/1-thaler.muttrc # mw-autogenerated
set mailcap_path = /home/philipp/.config/mutt/mailcap
macro index,pager i1 '<sync-mailbox><enter-command>source /home/philipp/.config/mutt/accounts/1-thaler.muttrc<enter><change-folder>!<enter>;<check-stats>' "switch to philipp@thaler.fyi" # mw-autogenerated
macro index,pager i2 '<sync-mailbox><enter-command>source /home/philipp/.config/mutt/accounts/2-tsn.muttrc<enter><change-folder>!<enter>;<check-stats>' "switch to phithaler@tsn.at" # mw-autogenerated

set query_command = "( khard email --parsable '%s' )" 
macro index,pager a "<pipe-message>khard add-email<return>" "add the sender email address to khard"

set date_format="%F %H:%M%p"

bind pager <up> previous-line #scroll inside the message rather than the index
bind pager <down> next-line
set sleep_time = 0 # be fast
set smart_wrap

# urlscan
macro index,pager \cb "<pipe-message> w3m -I "utf-8" -T text/html | urlscan<Enter>"
macro attach,compose \cb "<pipe-entry> w3m -I "utf-8" -T text/html | urlscan<Enter>"

# New mail is boldened:
color index black brightyellow "~N"
color index_author black brightred "~N"
color index_subject black brightcyan "~N"
